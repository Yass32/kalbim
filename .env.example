# ─── Public site URL (canonical + Open Graph) ───
NEXT_PUBLIC_SITE_URL=https://kalbim.org

# ─── Directus (headless CMS) ───
# Base URL of your self-hosted Directus instance (no trailing slash).
DIRECTUS_URL=https://cms.kalbim.org
# Optional static read-only token. Leave empty if the Public role has read
# permission on: kalbim, globals, categories, posts, directus_files.
DIRECTUS_TOKEN=
# Which `kalbim` site record this deployment serves (matched by slug).
DIRECTUS_SITE=kalbim
# Secret shared with the Directus revalidation webhook (see /api/revalidate).
REVALIDATE_SECRET=change-me
