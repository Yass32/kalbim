# ── Directus secrets (generate random values!) ──
# e.g.  openssl rand -hex 32
DIRECTUS_KEY=replace-with-random-32+chars
DIRECTUS_SECRET=replace-with-random-32+chars

# Public URL where Directus will be reachable (behind your reverse proxy)
PUBLIC_URL=https://cms.kalbim.org

# Postgres
DB_DATABASE=kalbim
DB_USER=kalbim
DB_PASSWORD=replace-with-strong-password

# First admin account (created on first boot)
ADMIN_EMAIL=admin@kalbim.org
ADMIN_PASSWORD=replace-with-strong-password

# Comma-separated origins allowed to call the API from a browser.
# Your Next.js site origin(s):
CORS_ORIGIN=https://kalbim.org,http://localhost:3000
